# Copy this file to .env and fill in real values.
# Local dev: point DATABASE_URL at a local Postgres (see README.md).
# Production: use the connection string from your managed Postgres (e.g. Neon).
DATABASE_URL="postgresql://user:password@localhost:5432/maxled_crm?schema=public"

# NextAuth — generate a real secret with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Secures /api/cron/advance-deals (the Agenda 3-business-day auto-advance).
# Optional locally; set it in production and configure the same value on
# whatever triggers the cron (e.g. Vercel Cron reads this automatically).
CRON_SECRET=""

# Powers the IA module (forecasting, suggestions, sentiment). Get one at
# console.anthropic.com — without it, IA features are disabled gracefully.
ANTHROPIC_API_KEY=""

# Copy this file to .env and fill in real values.
# Local dev: point DATABASE_URL at a local Postgres (see README.md).
# Production: use the connection string from your managed Postgres (e.g. Neon).
DATABASE_URL="postgresql://user:password@localhost:5432/maxled_crm?schema=public"

# NextAuth — generate a real secret with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

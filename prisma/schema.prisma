generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  SELLER
  SUPPORT
  MEDIATOR
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role      @default(SELLER)
  jobTitle       String?
  birthday       DateTime?
  goal1          Decimal?  @db.Decimal(12, 2)
  goal2          Decimal?  @db.Decimal(12, 2)
  commissionPct1 Decimal?  @db.Decimal(5, 2)
  commissionPct2 Decimal?  @db.Decimal(5, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  contacts     Contact[]     @relation("ContactOwner")
  deals        Deal[]        @relation("DealOwner")
  activityLogs ActivityLog[]
}

model Contact {
  id     String @id @default(cuid())
  ownerId String
  owner   User   @relation("ContactOwner", fields: [ownerId], references: [id])

  firstName        String
  lastName         String
  accountName      String?
  email            String?
  phone            String?
  mobile           String?
  residentialPhone String?
  assistantPhone   String?
  leadSource       String?
  supplierName     String?
  jobTitle         String?
  department       String?

  street     String?
  number     String?
  city       String?
  state      String?
  postalCode String?
  latitude   Float?
  longitude  Float?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  deals        Deal[]
  activityLogs ActivityLog[]

  @@index([ownerId])
  @@index([deletedAt])
}

model Pipeline {
  id        String          @id @default(cuid())
  name      String
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  stages    PipelineStage[]
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  name       String
  order      Int
  color      String?

  // Agenda automation (spec 3.4): the stage that triggers the "on the way"
  // 3-business-day countdown, and which stage it auto-advances into.
  isOnTheWay            Boolean        @default(false)
  autoAdvanceToStageId  String?
  autoAdvanceToStage    PipelineStage? @relation("AutoAdvance", fields: [autoAdvanceToStageId], references: [id])
  autoAdvanceFromStages PipelineStage[] @relation("AutoAdvance")

  deals Deal[]

  @@index([pipelineId])
}

model Deal {
  id        String        @id @default(cuid())
  ownerId   String
  owner     User          @relation("DealOwner", fields: [ownerId], references: [id])
  contactId String
  contact   Contact       @relation(fields: [contactId], references: [id])
  stageId   String
  stage     PipelineStage @relation(fields: [stageId], references: [id])

  name  String
  value Decimal @db.Decimal(12, 2)

  onTheWaySince    DateTime?
  onTheWayDeadline DateTime?
  postSaleSentAt   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  notes        DealNote[]
  activityLogs ActivityLog[]

  @@index([ownerId])
  @@index([contactId])
  @@index([stageId])
  @@index([deletedAt])
}

model DealNote {
  id            String   @id @default(cuid())
  dealId        String
  deal          Deal     @relation(fields: [dealId], references: [id])
  authorId      String?
  body          String?
  attachmentUrl String?
  createdAt     DateTime @default(now())

  @@index([dealId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  entityType String
  entityId   String
  action     String
  diff       Json?
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  dealId     String?
  deal       Deal?    @relation(fields: [dealId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

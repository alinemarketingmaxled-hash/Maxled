generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  SELLER
  SUPPORT
  MEDIATOR
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role      @default(SELLER)
  jobTitle       String?
  avatarUrl      String?   @db.Text
  birthday       DateTime?
  goal1          Decimal?  @db.Decimal(12, 2)
  goal2          Decimal?  @db.Decimal(12, 2)
  commissionPct1 Decimal?  @db.Decimal(5, 2)
  commissionPct2 Decimal?  @db.Decimal(5, 2)
  // Beyond goal2, commission climbs +0.02 points for every extra
  // commissionStepValue in revenue achieved past goal2 (open-ended).
  commissionStepValue Decimal? @db.Decimal(12, 2)
  personalGoal   Decimal?  @db.Decimal(12, 2)
  failedLoginAttempts Int       @default(0)
  lockedAt            DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  contacts     Contact[]     @relation("ContactOwner")
  deals        Deal[]        @relation("DealOwner")
  activityLogs ActivityLog[]
  posts        Post[]
  postLikes    PostLike[]
  postComments PostComment[]
  tasks        Task[]
  prospects    Prospect[]                @relation("ProspectOwner")
  activationReviews ClientActivationRequest[] @relation("ActivationReviewer")
}

enum PersonType {
  FISICA
  JURIDICA
}

enum CommercialPotential {
  ALTO
  MEDIO
  BAIXO
}

enum CrmStatus {
  LEAD
  ATIVO
  INATIVO
}

enum PaymentStatus {
  PENDENTE
  PARCIAL
  PAGO
}

model Contact {
  id     String @id @default(cuid())
  ownerId String
  owner   User   @relation("ContactOwner", fields: [ownerId], references: [id])

  personType       PersonType?
  firstName        String
  lastName         String
  accountName      String?
  cnpj             String?
  email            String?
  phone            String?
  mobile           String?
  residentialPhone String?
  assistantPhone   String?
  leadSource       String?
  supplierName     String?
  jobTitle         String?
  department       String?

  street     String?
  number     String?
  city       String?
  state      String?
  postalCode String?
  latitude   Float?
  longitude  Float?

  // Dados fiscais/financeiros (mesmos campos do Sintegra), preenchidos ao
  // aprovar uma prospecção como cliente ativo — ver ClientActivationRequest.
  inscricaoEstadual String?
  emailFinanceiro   String?
  emailNfe          String?
  enderecoEntrega   String? @db.Text

  birthday            DateTime?
  commercialPotential CommercialPotential?
  crmStatus           CrmStatus?
  lastContactedAt     DateTime?
  nextContactAt       DateTime?
  notes               String?              @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  deals        Deal[]
  activityLogs ActivityLog[]

  @@index([ownerId])
  @@index([deletedAt])
}

model Pipeline {
  id        String          @id @default(cuid())
  name      String
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  stages    PipelineStage[]
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  name       String
  order      Int
  color      String?

  // Marks the stage analytics treats as closed/won revenue (§3.1 KPIs).
  isWon Boolean @default(false)

  // Agenda automation (spec 3.4): the stage that triggers the "on the way"
  // 3-business-day countdown, and which stage it auto-advances into.
  isOnTheWay            Boolean        @default(false)
  autoAdvanceToStageId  String?
  autoAdvanceToStage    PipelineStage? @relation("AutoAdvance", fields: [autoAdvanceToStageId], references: [id])
  autoAdvanceFromStages PipelineStage[] @relation("AutoAdvance")

  deals Deal[]

  @@index([pipelineId])
}

model Deal {
  id        String        @id @default(cuid())
  ownerId   String
  owner     User          @relation("DealOwner", fields: [ownerId], references: [id])
  contactId String
  contact   Contact       @relation(fields: [contactId], references: [id])
  stageId   String
  stage     PipelineStage @relation(fields: [stageId], references: [id])

  name  String
  value Decimal @db.Decimal(12, 2)

  paymentStatus PaymentStatus @default(PENDENTE)
  paymentMethod String?

  onTheWaySince    DateTime?
  onTheWayDeadline DateTime?
  postSaleSentAt   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  notes             DealNote[]
  activityLogs      ActivityLog[]
  installments      DealInstallment[]
  scheduledMessages Task[]

  @@index([ownerId])
  @@index([contactId])
  @@index([stageId])
  @@index([deletedAt])
}

model DealInstallment {
  id        String    @id @default(cuid())
  dealId    String
  deal      Deal      @relation(fields: [dealId], references: [id])
  number    Int
  value     Decimal   @db.Decimal(12, 2)
  dueDate   DateTime
  paid      Boolean   @default(false)
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([dealId])
}

model DealNote {
  id            String   @id @default(cuid())
  dealId        String
  deal          Deal     @relation(fields: [dealId], references: [id])
  authorId      String?
  body          String?
  attachmentUrl String?
  flagged       Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([dealId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  entityType String
  entityId   String
  action     String
  diff       Json?
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  dealId     String?
  deal       Deal?    @relation(fields: [dealId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

/** Rede Social mural (spec §3.5): self-hosted, no external API — photos are
 * stored as data URLs, same approach as User.avatarUrl. */
model Post {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String?
  imageUrl  String?  @db.Text
  // Mediator-only flag (spec follow-up): highlights a post as an important
  // announcement, surfacing it in the home page's "Comunicados" sidebar card.
  important Boolean  @default(false)
  createdAt DateTime @default(now())

  likes    PostLike[]
  comments PostComment[]

  @@index([authorId])
  @@index([important])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([postId])
}

model Task {
  id         String    @id @default(cuid())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id])
  dealId     String?
  deal       Deal?     @relation(fields: [dealId], references: [id])
  prospectId String?
  prospect   Prospect? @relation(fields: [prospectId], references: [id])
  title      String
  dueDate    DateTime?
  done       Boolean   @default(false)
  doneAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([ownerId])
  @@index([dealId])
  @@index([prospectId])
}

enum ProspectTemperature {
  QUENTE
  MORNO
  FRIO
}

enum ActivationStatus {
  PENDENTE
  APROVADO
  RECUSADO
}

/** A coluna do quadro de Prospecções. As 6 primeiras (Prospecção,
 * Conversação, Retorno, Cotação, Negociação, Cliente Ativo) são fixas —
 * isCustom=false, não podem ser renomeadas nem excluídas. Qualquer usuário
 * com acesso de edição pode acrescentar colunas extras (isCustom=true),
 * que ficam sempre depois das fixas e são livremente renomeáveis/excluíveis. */
model ProspectStage {
  id            String   @id @default(cuid())
  name          String
  order         Int
  isClientStage Boolean  @default(false)
  isCustom      Boolean  @default(false)
  createdAt     DateTime @default(now())

  prospects   Prospect[]
  stageValues ProspectStageValue[]

  @@index([order])
}

/** Uma linha do quadro (um prospect/lead em captação, antes de virar Contact). */
model Prospect {
  id          String              @id @default(cuid())
  ownerId     String
  owner       User                @relation("ProspectOwner", fields: [ownerId], references: [id])
  name        String
  clientName  String
  phone       String?
  email       String?
  temperature ProspectTemperature @default(MORNO)
  profile     String
  notes       String?             @db.Text
  contactDate DateTime

  currentStageId String
  currentStage   ProspectStage @relation(fields: [currentStageId], references: [id])

  convertedContactId String?
  convertedAt         DateTime?
  lastTouchedAt        DateTime  @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  stageValues       ProspectStageValue[]
  activationRequest ClientActivationRequest?
  scheduledTasks    Task[]

  @@index([ownerId])
  @@index([currentStageId])
  @@index([deletedAt])
}

/** Uma célula da planilha: o preenchimento (data + observação + concluído)
 * de um prospect numa coluna específica. Uma por combinação prospect+coluna. */
model ProspectStageValue {
  id         String        @id @default(cuid())
  prospectId String
  prospect   Prospect      @relation(fields: [prospectId], references: [id])
  stageId    String
  stage      ProspectStage @relation(fields: [stageId], references: [id])
  date       DateTime?
  note       String?       @db.Text
  done       Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([prospectId, stageId])
  @@index([prospectId])
}

/** Preenchido ao mover um prospect pra coluna "Cliente Ativo" — mesmos
 * dados exigidos no Sintegra. Fica pendente até um Mediador aprovar ou
 * recusar; aprovar converte o Prospect num Contact + abre uma Negociação. */
model ClientActivationRequest {
  id         String   @id @default(cuid())
  prospectId String   @unique
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  razaoSocial         String
  cnpj                String
  emailFinanceiro     String
  emailNfe            String
  inscricaoEstadual   String
  enderecoFaturamento String  @db.Text
  enderecoEntrega     String  @db.Text
  valor               Decimal @db.Decimal(12, 2)
  condicaoPagamento   String

  status          ActivationStatus @default(PENDENTE)
  reviewerId      String?
  reviewer        User?            @relation("ActivationReviewer", fields: [reviewerId], references: [id])
  rejectionReason String?         @db.Text
  createdAt       DateTime         @default(now())
  decidedAt       DateTime?

  @@index([status])
}
